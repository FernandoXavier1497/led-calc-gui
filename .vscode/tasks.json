{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe arquivo de build ativo",
            "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
            "args": [
    "-fdiagnostics-color=always",
    "-g",
    "${workspaceFolder}\\main.c",
    "${workspaceFolder}\\calc.c",
    "${workspaceFolder}\\ui.c",
    "-I", "C:\\raylib\\include",
    "-L", "C:\\raylib\\lib",
    "-lraylib",
    "-lopengl32",
    "-lgdi32",
    "-lwinmm",
    "-lm",
    "-o",
    "${fileDirname}\\${fileBasenameNoExtension}.exe"
],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarefa gerada pelo Depurador."
        }
    ]
}